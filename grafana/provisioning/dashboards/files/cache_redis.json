{
  "annotations": { "list": [ { "builtIn": 1, "datasource": "-- GraphicWalker --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "panels": [
    {
      "datasource": "${datasource}",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [ { "datasource": "${datasource}", "expr": "redis_memory_used_bytes{job='redis'}", "legendFormat": "Memoria en Uso", "refId": "A" } ],
      "title": "Uso de Memoria (Redis)",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [ { "datasource": "${datasource}", "expr": "rate(redis_keyspace_hits_total{job='redis'}[5m]) / (rate(redis_keyspace_hits_total{job='redis'}[5m]) + rate(redis_keyspace_misses_total{job='redis'}[5m])) * 100", "legendFormat": "Tasa de Aciertos (%)", "refId": "A" } ],
      "title": "Caché Hit Rate (Eficiencia)",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "datasource": "${datasource}", "expr": "rate(redis_commands_total[5m])", "legendFormat": "Comandos/seg", "refId": "A" } ],
      "title": "Comandos Ejecutados (Throughput)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [ "redis", "cache" ],
  "title": "AutoExec: Caché (Redis)",
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrl": false,
        "type": "datasource"
      }
    ]
  },
  "uid": "cache-redis",
  "version": 1
}
